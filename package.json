{
    "name": "@goobits/themes",
    "version": "1.3.2",
    "description": "A reusable theme system for SvelteKit projects with Svelte 5 runes support",
    "type": "module",
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./goo": {
            "types": "./dist/goo/index.d.ts",
            "svelte": "./dist/goo/index.js",
            "default": "./dist/goo/index.js"
        },
        "./goo/*": {
            "types": "./dist/goo/*.d.ts",
            "svelte": "./dist/goo/*",
            "default": "./dist/goo/*"
        },
        "./core": {
            "types": "./dist/core/index.d.ts",
            "svelte": "./dist/core/index.js",
            "default": "./dist/core/index.js"
        },
        "./core/*": {
            "types": "./dist/core/*.d.ts",
            "svelte": "./dist/core/*",
            "default": "./dist/core/*"
        },
        "./svelte": {
            "types": "./dist/svelte/index.d.ts",
            "svelte": "./dist/svelte/index.js",
            "default": "./dist/svelte/index.js"
        },
        "./svelte/*": {
            "types": "./dist/svelte/*.d.ts",
            "svelte": "./dist/svelte/*",
            "default": "./dist/svelte/*"
        },
        "./server": {
            "types": "./dist/server/index.d.ts",
            "default": "./dist/server/index.js"
        },
        "./server/goo": {
            "types": "./dist/server/gooSsr.d.ts",
            "default": "./dist/server/gooSsr.js"
        },
        "./server/*": {
            "types": "./dist/server/*.d.ts",
            "default": "./dist/server/*"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "default": "./dist/utils/index.js"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "default": "./dist/utils/*"
        },
        "./themes/bundle.css": "./themes/bundle.css",
        "./themes": "./themes/index.css",
        "./themes/*": "./themes/*",
        "./themes/goo": "./themes/goo/index.css",
        "./themes/goo/base.css": "./themes/goo/base.css",
        "./themes/goo/bundle.css": "./themes/goo/bundle.css",
        "./themes/goo/pairs.json": "./themes/goo/pairs.json",
        "./themes/goo/presets/*": "./themes/goo/presets/*",
        "./themes/base": "./themes/base/index.css",
        "./themes/base/*": "./themes/base/*",
        "./themes/base/design-tokens.css": "./themes/base/design-tokens.css",
        "./themes/base/fx-tokens.css": "./themes/base/fx-tokens.css",
        "./themes/base/reset.css": "./themes/base/reset.css",
        "./themes/presets/*": "./themes/presets/*",
        "./themes/default.css": "./themes/presets/default.css",
        "./themes/spells.css": "./themes/presets/spells.css",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*",
        "themes",
        "README.md",
        "LICENSE"
    ],
    "peerDependencies": {
        "@lucide/svelte": ">=0.400.0",
        "@sveltejs/kit": "^2.0.0",
        "svelte": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "@lucide/svelte": {
            "optional": true
        }
    },
    "scripts": {
        "package": "svelte-package",
        "build": "svelte-package",
        "prepublishOnly": "pnpm run generate:goo && pnpm run package",
        "release": "pnpm run lint && pnpm run generate:goo && pnpm version patch --no-git-tag-version && pnpm run package && git add package.json pnpm-lock.yaml themes/goo && node scripts/commitRelease.cjs && pnpm publish --access public",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --max-warnings 10",
        "lint:fix": "eslint . --fix",
        "check": "npm run build && npm run lint && npm run test",
        "generate:goo": "tsx scripts/generateGooPresets.ts",
        "check:goo": "tsx scripts/checkGooPresets.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@lucide/svelte": "^1.21.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.67.0",
        "@sveltejs/package": "^2.5.8",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.4.1",
        "@types/node": "^26.0.0",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/ui": "^4.1.9",
        "eslint": "^10.5.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-svelte": "^3.19.0",
        "jsdom": "^29.1.1",
        "svelte": "^5.56.3",
        "svelte-eslint-parser": "^1.8.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    },
    "keywords": [
        "svelte",
        "sveltekit",
        "themes",
        "theming",
        "dark-mode",
        "color-schemes",
        "svelte-5",
        "runes"
    ],
    "license": "MIT",
    "author": "GooBits",
    "homepage": "https://github.com/goobits/goobits-themes#readme",
    "bugs": {
        "url": "https://github.com/goobits/goobits-themes/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/goobits/goobits-themes.git"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "overrides": {
        "cookie": "^0.7.0"
    },
    "pnpm": {
        "peerDependencyRules": {
            "allowedVersions": {
                "@lucide/svelte": "1"
            }
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "esm-env": "^1.2.2"
    }
}
