{
  "name": "@goobits/themes",
  "version": "1.0.0",
  "description": "A reusable theme system for SvelteKit projects with Svelte 5 runes support",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./core": "./core/index.ts",
    "./svelte": "./svelte/index.ts",
    "./svelte/*": "./svelte/*",
    "./server": "./server/index.ts",
    "./utils": "./utils/index.ts",
    "./themes/default.css": "./themes/default.css",
    "./themes/spells.css": "./themes/spells.css",
    "./package.json": "./package.json"
  },
  "files": [
    "core",
    "svelte",
    "server",
    "themes",
    "utils",
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "scripts": {
    "package": "svelte-package",
    "build": "svelte-package && tsc",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.46.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "themes",
    "theming",
    "dark-mode",
    "color-schemes",
    "svelte-5",
    "runes"
  ],
  "license": "MIT",
  "author": "GooBits",
  "homepage": "https://github.com/goobits/goobits-themes#readme",
  "bugs": {
    "url": "https://github.com/goobits/goobits-themes/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goobits/goobits-themes.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
